        },
        {
          "name": "margin-api",
          "type": "internal-api",
          "auth": "service-account",
          "access": "read-only",
          "key_metrics": ["contribution_margin_pct", "poas"],
          "phase": "phase-1"
        },
        {
          "name": "categories-api",
