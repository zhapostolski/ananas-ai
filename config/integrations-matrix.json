          "type": "mcp",
          "auth": "oauth2",
          "access": "read-only",
          "key_metrics": ["spend", "cpc", "cvr"],
          "phase": "phase-1"
        },
        {
          "name": "x-ads",
          "type": "mcp",
          "auth": "oauth2",
          "access": "read-only",
          "key_metrics": ["spend", "engagement"],
          "note": "X profile does not yet exist — account creation is on team roadmap",
          "phase": "phase-1"
        },
        {
          "name": "tiktok-ads",
          "type": "mcp",
          "auth": "oauth2",
          "access": "read-only",
          "key_metrics": ["spend", "cvr", "cpm"],
          "phase": "phase-1"
        },
        {
          "name": "ga4",
          "type": "mcp",
          "auth": "service-account",
          "access": "read-only",
          "key_metrics": ["sessions", "users", "cvr", "revenue", "organic_sessions"],
          "phase": "phase-1",
          "status": "LIVE — tested and working 2026-03-13"
