          "phase": "phase-1"
        },
        {
          "name": "meta-ads",
          "type": "mcp",
          "auth": "app-token",
          "access": "read-only",
          "key_metrics": ["spend", "roas", "cpm", "cvr"],
          "phase": "phase-1"
        },
        {
