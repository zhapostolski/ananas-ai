      "auth_type": "CLIENT_CREDENTIALS",
      "env_vars": ["ANANAS_API_CLIENT_ID", "ANANAS_API_CLIENT_SECRET"],
      "implementation": "src/ananas_ai/integrations/ananas_api.py",
      "connectors": [
        {
          "name": "orders-api",
          "type": "internal-api",
          "path": "/order/api/v1/orders",
          "auth": "client-credentials",
          "access": "read-only",
          "key_metrics": ["orders", "revenue", "aov", "status_breakdown"],
          "phase": "phase-1"
        },
        {
          "name": "returns-api",
          "type": "internal-api",
          "auth": "service-account",
          "access": "read-only",
