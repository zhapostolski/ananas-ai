# ── Ananas AI Platform — EC2 environment variables ──────────────────────────
# Copy to /home/ubuntu/ananas-ai/.env on EC2 and fill in real values.
# This file is safe to commit. The real .env is gitignored.

# ── Google Ads (service account auth) ───────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=eXEYMMzTsTSxcJZUrXIiUA
GOOGLE_ADS_SERVICE_ACCOUNT_FILE=/home/ubuntu/ananas-ai/secrets/google-service-account.json
GOOGLE_ADS_LOGIN_CUSTOMER_ID=2135950127
# Comma-separated active sub-accounts (Search MK, Display MK x2, YouTube MK)
GOOGLE_ADS_CUSTOMER_IDS=5832113533,9993867198,8508967046,4783821547

# ── Google Analytics 4 ──────────────────────────────────────────────────────
GA4_PROPERTY_ID=374249510
GA4_CREDENTIALS=/home/ubuntu/ananas-ai/secrets/google-service-account.json
# ACTION NEEDED: add ananas-ai@boreal-coyote-490215-p5.iam.gserviceaccount.com
# as Viewer in GA4 Admin -> Property Access Management before this will work.

# ── Meta Ads ────────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=REPLACE_WITH_LONG_LIVED_TOKEN
META_AD_ACCOUNT_ID=act_174735152216843
# Long-lived token expires ~60 days after exchange (~2026-05-14).
# App ID: 1282302996494665

# ── Azure AD (portal auth) ───────────────────────────────────────────────────
AZURE_AD_CLIENT_ID=3d0a6854-b742-461d-b98a-420efd6fd8dd
AZURE_AD_CLIENT_SECRET=REPLACE_WITH_SECRET
AZURE_AD_TENANT_ID=c764ab62-ad43-4930-aa38-c9e23a990cb0

# ── Next.js portal ───────────────────────────────────────────────────────────
AUTH_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET
NEXTAUTH_URL=https://ai.ananas.mk
DB_PATH=/home/ubuntu/ananas-ai/ananas_ai.db

# ── Database ─────────────────────────────────────────────────────────────────
ANANAS_DB_PATH=/home/ubuntu/ananas-ai/ananas_ai.db

